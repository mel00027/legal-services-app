# Додайте свій токен бота сюди
# Отримати токен можна у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# ID чату адміністраторів (група-форум в Telegram)
ADMIN_CHAT_ID=your_admin_chat_id_here

# Шлях до файлу бази даних (за замовчуванням: /var/data/legalclick/database.sqlite)
# ВАЖЛИВО: має бути ПОЗА папкою коду, щоб деплой не затирав дані!
# Приклад для VPS: /var/data/legalclick/database.sqlite
# Приклад для локальної розробки: ./database.sqlite
DB_PATH=/var/data/legalclick/database.sqlite
