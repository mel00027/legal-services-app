# ── Обов'язкові (бот не стартує без них) ──────────────────────────

# Токен бота від @BotFather
BOT_TOKEN=your_bot_token_here

# ID групи-форуму адміністраторів (отримати через /getid)
ADMIN_CHAT_ID=-100xxxxxxxxxx

# ID групи для ведення справ у топіках (якщо той самий чат — не вказуйте)
# CASES_CHAT_ID=-100xxxxxxxxxx

# Посилання на оплату Monobank (jar / invoice link)
MONOBANK_PAYMENT_LINK=https://send.monobank.ua/jar/xxxxxxxxxx

# ── Опційні ──────────────────────────────────────────────────────

# Шлях до файлу бази даних
# ВАЖЛИВО: має бути ПОЗА папкою коду, щоб деплой не затирав дані!
# Приклад для VPS: /var/data/legalclick/database.sqlite
# Приклад для локальної розробки: ./database.sqlite
# DB_PATH=/var/data/legalclick/database.sqlite
